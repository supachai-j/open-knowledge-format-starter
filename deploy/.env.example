# Copy to .env and fill in for your internal site.
# Internal git remote the MCP server clones/pulls the bundle from:
OKF_GIT_REMOTE=http://gitea:3000/okf/knowledge.git

# Gitea API for auto-opening PRs from okf_propose_change (optional but recommended):
OKF_GITEA_API=http://gitea:3000/api/v1
OKF_GITEA_TOKEN=replace-with-a-gitea-token
OKF_GITEA_OWNER=okf
OKF_GITEA_REPO=knowledge

# Bearer token agents must present to the proxy:
OKF_TOKEN=replace-with-a-long-random-token

# Set to 1 to run a reader-only MCP replica (disables okf_propose_change):
OKF_READONLY=0
